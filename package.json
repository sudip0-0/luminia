{
  "name": "lumina",
  "version": "0.1.0",
  "private": true,
  "description": "Lumina - anti-doomscroll knowledge feed (monorepo root)",
  "license": "UNLICENSED",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
